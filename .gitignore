# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!**/.env.example

# -----------------------------------------------------------------------------
# Build outputs & caches (Vite / bundlers)
# -----------------------------------------------------------------------------
dist/
build/
.vite/

# -----------------------------------------------------------------------------
