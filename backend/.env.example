# Copy to .env for local development only. On Vercel, set these in:
# Project → Settings → Environment Variables (Production / Preview as needed).

# Required for POST /chat
OPENAI_API_KEY=

# Optional — Postgres / Neon (GET /admin/*, lead storage). Same value style as Neon dashboard.
# DATABASE_URL=postgresql://...
# POSTGRES_URL=postgresql://...
# POSTGRES_PRISMA_URL=postgresql://...

# Optional — lock /admin/* JSON + exports (Bearer token)
# ADMIN_API_KEY=

# Optional — public URL shown in GET /config (your https://….vercel.app)
# PUBLIC_API_URL=

# Optional — OpenAI sampling 0–2 (default 0.45 = steadier, answer-first behavior)
# CHAT_TEMPERATURE=0.45

# Optional — default chatbot slug (see backend/bots.js)
# BOT_SLUG=aeromaverick

# Optional — admin workspace toggles (see backend/bots.js)
# ADMIN_SINGLE_WORKSPACE=true
# ADMIN_VISIBLE_BOTS=

# Optional — force Excel mirror of leads (in addition to DB when DATABASE_URL is set)
# SAVE_LEADS_TO_EXCEL=true

# Optional — local only; on Vercel, LEADS_FILE defaults to /tmp/…
# LEADS_FILE=leads.xlsx

# Optional — disable SSL for DB (default: SSL on)
# DATABASE_SSL=false
