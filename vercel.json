{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install --prefix backend && npm install --prefix admin_panel",
  "buildCommand": "npm run build --prefix admin_panel",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["admin_panel/dist/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "backend/server.js" }]
}
